{
  "name": "growi-plugin-theme-outline",
  "version": "1.0.0",
  "description": "GROWI theme plugin inspired by Outline wiki's clean, minimal design language",
  "license": "MIT",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && echo '// GROWI Outline theme' > dist/index.js",
    "dev": "vite build --watch",
    "lint": "run-s lint:biome lint:style",
    "lint:biome": "biome check --no-errors-on-unmatched --files-ignore-unknown=true",
    "lint:style": "stylelint --cache --cache-location node_modules/.cache/stylelint 'src/**/*.scss'",
    "test": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.7.3",
    "@growi/core-styles": "^1.0.0",
    "@growi/pluginkit": "^1.0.0",
    "bootstrap": "^5.3.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.2",
    "stylelint": "^16.5.0",
    "stylelint-config-recess-order": "^5.0.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "growiPlugin": {
    "schemaVersion": "4",
    "types": [
      "theme"
    ],
    "themes": [
      {
        "name": "outline",
        "manifestKey": "src/styles/style.scss",
        "schemeType": "both",
        "lightBg": "#ffffff",
        "darkBg": "#111319",
        "lightSidebar": "#edf2f7",
        "darkSidebar": "#08090c",
        "lightIcon": "#0366d6",
        "darkIcon": "#137ffb",
        "createBtn": "#0366d6"
      }
    ]
  }
}
